# Configuración de Acceso al Correo (Gmail/IMAP)
# Importante: Para Gmail, utilice una "Contraseña de Aplicación" de 16 caracteres.
EMAIL_USER="tu_correo@gmail.com"
EMAIL_PASS="tu_contraseña_de_aplicación"

# Configuración del Servidor (Predeterminado: Gmail)
IMAP_SERVER="imap.gmail.com"

# Parámetros Operativos
CHECK_INTERVAL=300
DATA_FILE="data/contactos.xlsx"
LOG_FILE="logs/system.log"

# Configuración de IA (Gemini API)
# Obtenga su llave gratuita en: https://aistudio.google.com/
GEMINI_API_KEY_1="tu_api_key_aquí"

# Opcional: Llaves adicionales para evitar límites de cuota (Rate Limits)
# GEMINI_API_KEY_2="otra_api_key_aquí"
# GEMINI_API_KEY_3="otra_api_key_aquí"
